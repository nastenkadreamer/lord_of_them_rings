*------------------------------------------------------------------------------*
* Within-GP Variation
*------------------------------------------------------------------------------*

* Intracluster correlations (ICC) for key variables
* ICC measures variation within vs between clusters (GPs)

* For water sufficiency
loneway q8_8_sufficient_last_yr gp_id
local icc_water = r(rho)
display "ICC for water sufficiency: `icc_water'"

* For community collective
loneway q4_9_community_collective gp_id
local icc_collective = r(rho)
display "ICC for community collective: `icc_collective'"

* For family trust
loneway q4_2_family_trust gp_id
local icc_trust = r(rho)
display "ICC for family trust: `icc_trust'"

* For reciprocity belief
loneway beh_recip1 gp_id
local icc_recip = r(rho)
display "ICC for reciprocity: `icc_recip'"

* Update ICC table
clear
set obs 4
gen str20 variable = ""
gen icc = .
replace variable = "Water Sufficiency" in 1
replace icc = `icc_water' in 1
replace variable = "Community Collective" in 2
replace icc = `icc_collective' in 2
replace variable = "Family Trust" in 3
replace icc = `icc_trust' in 3
replace variable = "Reciprocity" in 4
replace icc = `icc_recip' in 4
export delimited using "${myoutput}/Tables/Citizen_Survey/citizen_icc.csv", replace

* Reload data
use "${interdata}/01_Baseline_Survey/02_citizen_survey/citizen_survey_barwani.dta", clear

* Summary by GP for key variables
estpost tabstat q8_8_sufficient_last_yr q4_9_community_collective q4_2_family_trust beh_recip1, by(gp_id) statistics(mean sd) columns(statistics)
eststo gp_summary
esttab gp_summary using "${myoutput}/Tables/Citizen_Survey/citizen_gp_summary.tex", ///
    cells("mean sd") label replace booktabs title("Summary by GP: Key Variables (Citizen)") ///
    note("Note: See above for variable scales.")

