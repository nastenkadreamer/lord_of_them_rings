*------------------------------------------------------------------------------*
* Overall Water Access Section
*------------------------------------------------------------------------------*

* Summary statistics for water access

*--- inputs
eststo clear

preserve 
statsby ///
    mean=r(mean) sd=r(sd) min=r(min) max=r(max) N=r(N), ///
    by(gp_id) clear : ///
    summarize q8_8_sufficient_last_yr , detail //q8_37_lack_irr

* Optional formatting (so LaTeX looks nice)
format mean sd %9.3f
format min max %9.0f
format N %9.0f

listtab gp_id mean sd min max N if !mi(gp_id) using "${myoutput}/Tables/Citizen_Survey/citizen_water_by_gp.tex", ///
    replace rstyle(tabular) ///
    head("\begin{table}[htbp]\centering\caption{Household Lacked Sufficient Water for Own Use (Past Year)} \begin{tabular}{lccccc}\toprule GP & Mean & SD & Min & Max & N\\ \midrule") ///
    foot("\bottomrule\end{tabular}\end{table}") 

	restore
	
* Tabulation of primary drinking water sources
qui tab q8_1_primary_drinking_source, gen(pri_ds)
	lab var pri_ds1 "Other" // is this possibly wrong? 
	lab var pri_ds2 "Borehole or tubewell"
	lab var pri_ds3 "Well"
	lab var pri_ds4 "Surface water"
	lab var pri_ds5 "Tanker"
	lab var pri_ds6 "Water tank"
eststo water_sources: estpost sum pri_ds2 pri_ds3 pri_ds4 pri_ds5 pri_ds6 pri_ds1, d


esttab water_sources using "${myoutput}/Tables/Citizen_Survey/citizen_water_sources.tex", ///
    cells("mean sd count") label replace booktabs title("Distribution of Primary Drinking Water Sources (Citizen)")

