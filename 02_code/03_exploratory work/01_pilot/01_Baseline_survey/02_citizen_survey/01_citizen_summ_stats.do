*------------------------------------------------------------------------------*
// shorten variables: 

g comm_coh1 = (q4_9_community_collective == 1)
	lab var comm_coh1 "Community would come together to solve problem"

g comm_coh2 = (q4_4_other_village_people_trust == 1 | q4_4_other_village_people_trust == 2)
	lab var comm_coh2 "Other villagers completely or somewhat trustworthy"
	
g comm_coh3 = (q4_5_leaders_trust == 1 | q4_5_leaders_trust  == 2)
	lab var comm_coh3 "Village leaders completetely or somewhat trustworthy"

g conflict_vill = (q4_8_conflict_village  ==1 | q4_8_conflict_village == 2)
	lab var conflict_vill "A lot or some conflict in village"

g leaders_help = (q4_6_leaders_help == 1)
	lab var leaders_help "Local leaders able to help people receive benefits"

g untouch = (q4_10_untouchability == 1 | q4_10_untouchability == 2)
	lab var untouch "Many or some households practice untouchability"
	

* Summary statistics for cooperation and cohesion
estpost summarize comm_coh1 comm_coh2 comm_coh3 leaders_help conflict_vill untouch
eststo cooperation_summary
esttab cooperation_summary using "${myoutput}/Tables/Citizen_Survey/citizen_cooperation_summary.tex", ///
    cells("mean sd min max") label replace booktabs title("Summary Statistics: Community Cooperation and Cohesion (Citizen)") ///
    note("Note: Trust variables: 1=Not trustworthy at all, 4=Completely trustworthy.")
	
	
	
preserve 
collapse ///
    (mean) comm_coh1 comm_coh2 comm_coh3 leaders_help conflict_vill untouch ///
    (count) N = comm_coh1 if gp_id != ., ///
    by(gp_id)

* Optional formatting (so LaTeX looks nice)
format comm_coh* leaders_help conflict_vill untouch %9.3f
format N %9.0f


listtab gp_id comm_coh1 comm_coh2 comm_coh3 leaders_help conflict_vill untouch N ///
    using "${myoutput}/Tables/Citizen_Survey/citizen_coop_byGP.tex", ///
    replace rstyle(tabular) ///
    head("\begin{table}[htbp]\centering  \caption{Mean Survey Responses by Gram Panchayat}    \begin{tabular}{lccccccc}\toprule GP & Coh1 & Coh2 & Coh3 & Leaders Help & Conflict & Untouch & N \\\midrule") ///
    foot("\bottomrule\end{tabular}\end{table}")


	restore	
	
	
// alt: variables as rows, GPs as columns: 
eststo clear

levelsof gp_id if !missing(gp_id), local(gps)

foreach g of local gps {
    quietly mean comm_coh1 comm_coh2 comm_coh3 leaders_help conflict_vill untouch if gp_id==`g'
    estimates store gp`g'
    estadd scalar N`g' = e(N)
}

